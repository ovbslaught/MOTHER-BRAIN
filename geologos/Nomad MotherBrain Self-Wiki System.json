    {
      "parameters": {
        "functionCode": "item.errors = [];\ntry {\n  if (item.mimeType.includes('python') || item.name.match(/\\.py$/)) {\n    // Attempt syntax check (example only; expand for batch/ps/sh later)\n    const { execSync } = require('child_process');\n    execSync(`python -m py_compile ${item.path}`);\n    item.status = 'OK';\n  } else {\n    item.status = 'Unchecked';\n  }\n} catch (e) {\n  item.status = 'Error';\n  item.errors.push(e.message);\n}\nreturn item;"
      },
      "id": "d844cb94-fa76-416c-ad6f-2fcf54737508",
      "name": "Lint/Validate Code",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        -416,
        32
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "{{ $json[\"status\"] }}",
              "value2": "Error"
            }
          ]
        }
      },
      "id": "2ef6d48e-f1aa-4834-b1a7-a689b2cbb986",
      "name": "Has Errors?",
