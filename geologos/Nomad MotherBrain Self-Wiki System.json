        "functionCode": "// Log valid or fixed scripts for future wiki\nreturn {\n  file: item.name,\n  status: item.status,\n  timestamp: new Date(),\n  notes: item.errors && item.errors.length > 0 ? item.errors.join('; ') : 'No errors',\n  path: item.path\n};"
