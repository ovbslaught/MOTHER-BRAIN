# MOTHER-BRAIN .gitignore

# Environment variables (NEVER commit these!)
.env
*.env

# Credentials and sensitive data
credentials/
*.json.key
*.pem
*.key
*.p12

# API keys and tokens
api_keys.txt
tokens/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
PIPFILE.lock

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Godot
.godot/
*.import
export_presets.cfg

# Blender
*.blend1
*.blend2

# Logs and temporary files
logs/
*.log
temp/
tmp/
*.tmp
*.bak
*.swp
*.swo

# Data files (local only)
data/*.db
data/*.sqlite
data/*.db-wal
data/*.db-shm

# Backups
backups/
*.backup

# System files
Thumbs.db
Desktop.ini

# Node modules (if using Node.js)
node_modules/
package-lock.json

# Build outputs
builds/
output/
dist/

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# PyCharm
.idea/
