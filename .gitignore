# Ignore everything by default
/*

# But keep these top-level paths
!.gitignore
!Scripts/
!Config/
!notes/

# Ensure Git will traverse into these dirs
!Scripts/**
!Config/**
!notes/**

# Still ignore Obsidian app-state + secrets even inside notes
.obsidian/
Security/
notes/**/.DS_Store

# Logs should not be in Git
99_System_Logs/
00SYSTEM/logs/
*.log

# --- DO NOT TRACK LOGS IN GIT ---
99_System_Logs/
00SYSTEM/logs/
**/logs/
*.log
