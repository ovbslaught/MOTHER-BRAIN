# MOTHER-BRAIN Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real credentials!

# API Keys
PERPLEXITY_API_KEY=your_perplexity_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=ovbslaught/MOTHER-BRAIN
GITHUB_BRANCH=Cosmic-key

# Google Drive
GDRIVE_CREDENTIALS_PATH=./credentials/gdrive_credentials.json
GDRIVE_MOUNT_POINT=/mnt/gdrive

# Termux SSH
TERMUX_SSH_HOST=termux.local
TERMUX_SSH_PORT=8022
TERMUX_SSH_USER=u0_a123
TERMUX_SSH_KEY_PATH=~/.ssh/termux_key

# Oracle Cloud (if used)
ORACLE_CLOUD_USER=your_oracle_cloud_user
ORACLE_CLOUD_KEY_PATH=~/.ssh/oracle_cloud_key
ORACLE_CLOUD_HOST=your_oracle_instance_ip

# Database
DATABASE_PATH=./data/mother_brain.db
BACKUP_PATH=./backups

# Logging
LOG_LEVEL=INFO
LOG_PATH=./logs

# Automation Settings
AUTO_SYNC_ENABLED=false
SYNC_INTERVAL_MINUTES=30
MAX_CONCURRENT_TASKS=3

# Blender
BLENDER_PATH=/usr/bin/blender
BLENDER_HEADLESS=true

# Godot
GODOT_PATH=/usr/bin/godot
GODOT_PROJECT_PATH=./godot_projects/NOMADZ-0
